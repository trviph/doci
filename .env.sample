# ============================================================================
# doci — environment sample
# ----------------------------------------------------------------------------
# Local endpoints below match `docker compose -f docker/compose.yml up`.
# Required secrets are left BLANK — fill them in.
# Optional vars are COMMENTED OUT — uncomment to override the shown default.
# Copy to `.env` (gitignored). Note: the app does NOT auto-load .env; export it
# (e.g. `set -a; . ./.env; set +a`) or use your process manager / make target.
# ============================================================================

# --- Runtime / service ------------------------------------------------------
ENVIRONMENT=development
# SERVICE_VERSION=                       # defaults to installed package version

# --- API / worker server (commands/api.py, all_in_one.py) -------------------
HOST=localhost
PORT=8000

# --- Worker monitor server (commands/worker_mon.py; also bound by all_in_one) -
MON_HOST=localhost
MON_PORT=8001

# ============================================================================
# Postgres  (compose.postgres.yml → localhost:5432, db/user/pass = doci)
# A full DSN takes precedence over the discrete PG* fields below.
# ============================================================================
DATABASE_URL=postgresql://doci:doci@localhost:5432/doci
# POSTGRES_DSN=                          # alias for DATABASE_URL
PGHOST=localhost
PGPORT=5432
PGDATABASE=doci
PGUSER=doci
PGPASSWORD=doci
PGSSLMODE=disable                        # local has no TLS; prod default is "require"
# PGCONNECT_TIMEOUT=10
# PGAPPNAME=doci
# POSTGRES_POOL_MIN=1
# POSTGRES_POOL_MAX=10

# ============================================================================
# Object store / S3  (compose.minio.yml → localhost:9000, console :9001)
# MinIO root creds = doci / doci12345. The minio-init service creates the
# bucket and sets a 3-day object expiry on `docker compose up`.
# ============================================================================
S3_ENDPOINT_URL=http://localhost:9000
S3_PUBLIC_ENDPOINT_URL=http://localhost:9000   # used to sign URLs handed to clients
S3_REGION=us-east-1
# AWS_REGION=                            # fallback for S3_REGION if it is unset
S3_ACCESS_KEY_ID=doci
S3_SECRET_ACCESS_KEY=doci12345
S3_BUCKET=doci
# S3_PRESIGN_EXPIRY=900
# S3_FORCE_PATH_STYLE=true               # required for MinIO; false for real AWS S3

# ============================================================================
# Key-value store — Valkey/Redis  (compose.valkey.yml → localhost:6379)
# REDIS_URL takes precedence over the discrete REDIS_* fields below.
# ============================================================================
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=                        # local Valkey has no auth
# REDIS_SSL=false
# REDIS_KEY_PREFIX=
# REDIS_DEFAULT_TTL=                     # seconds; unset = no default TTL
# REDIS_MAX_CONNECTIONS=10

# ============================================================================
# TaskIQ — Redis Stream broker + result backend + dev monitor (Valkey db 1)
# ============================================================================
TASKIQ_BROKER_URL=redis://localhost:6379/1
# TASKIQ_QUEUE_NAME=taskiq               # Redis stream key
# TASKIQ_CONSUMER_GROUP=taskiq
# TASKIQ_IDLE_TIMEOUT_MS=1800000         # 30 min; MUST exceed longest task runtime
# TASKIQ_STREAM_MAXLEN=10000             # approx cap on stream length (~ trim on XADD)
# TASKIQ_UNACK_LOCK_TIMEOUT=60           # seconds; XAUTOCLAIM lock release
# TASKIQ_RESULT_PREFIX=taskiq:result     # per-task_id result payload keys
# TASKIQ_RESULT_TTL_S=259200             # 3 days
# TASKIQ_MONITOR_PREFIX=taskmon          # listable lifecycle index keys
# TASKIQ_MONITOR_TTL_S=259200            # 3 days

# ============================================================================
# Workflows — LangGraph (document-mining: image + PDF branches)
# Custom Valkey-backed durable checkpointer (db 2); every key carries a TTL so
# abandoned runs self-expire.
# ============================================================================
# DOCI_CHECKPOINT_REDIS_URL=redis://localhost:6379/2
# DOCI_CHECKPOINT_TTL=259200             # seconds; default 3 days
# DOCI_CHECKPOINT_PREFIX=doci:ckpt:
DOCI_PDF_PAGE_CONCURRENCY=1              # parallel page fan-out in the PDF branch
#                                        # (1 = serial; suits a local single-seq vLLM)
# DOCI_RESULTS_DIR=                      # where extract/annotation results are
#                                        # written; default: <tmpdir>/doci-results

# ============================================================================
# LLM  (LangChain init_chat_model; "provider:model")
# Per-task override: DOCI_LLM_<TASK>_<FIELD>  →  shared: DOCI_LLM_<FIELD>
# Tasks: ANNOTATE_TEXT, ANNOTATE_IMAGE, EXTRACT_IMAGE
# (all default to model openai:gpt-5-nano-2025-08-07)
# ============================================================================
# --- REQUIRED secret: provider API key (or set the provider-native var) -----
OPENAI_API_KEY=sk-local                  # dummy: local vLLM ignores it, but the
                                         # OpenAI client requires a non-empty value
# DOCI_LLM_API_KEY=                      # overrides provider-native key for all tasks

# --- Shared LLM defaults (optional) -----------------------------------------
# DOCI_LLM_MODEL=openai:gpt-5-nano-2025-08-07
# DOCI_LLM_BASE_URL=                     # OpenAI-compatible / local gateway endpoint
# OPENAI_BASE_URL=                       # fallback base_url if DOCI_LLM_BASE_URL unset
# DOCI_LLM_MAX_TOKENS=4096
# DOCI_LLM_TIMEOUT=60
# DOCI_LLM_MAX_RETRIES=2
# DOCI_LLM_TEMPERATURE=                  # opt-in; omitted when unset
# DOCI_LLM_PARAMS={}                     # JSON of extra model kwargs
# DOCI_LLM_TRACE_CONTENT=false           # capture raw LLM prompts/responses (incl.
#                                        # base64 images, PII) in OTel spans. Off by
#                                        # default; token/model/timing always traced.

# --- Per-task overrides (optional examples) ---------------------------------
# DOCI_LLM_ANNOTATE_TEXT_MODEL=openai:gpt-5-nano-2025-08-07
# DOCI_LLM_ANNOTATE_IMAGE_MODEL=openai:gpt-5-nano-2025-08-07
# DOCI_LLM_EXTRACT_IMAGE_MODEL=openai:gpt-5-nano-2025-08-07

# --- Local vLLM (compose.vllm.yml → localhost:8100, serves "qwen3.5-4b") -----
# Active: every LLM task points at the local vLLM server (with OPENAI_API_KEY
# above set to the sk-local dummy). The vLLM server itself is GPU-only — start
# it with `docker compose --profile gpu up` on the GPU box.
DOCI_LLM_BASE_URL=http://localhost:8100/v1
DOCI_LLM_MODEL=openai:qwen3.5-4b
# HUGGING_FACE_HUB_TOKEN=                # only if Qwen3.5-4B is gated on HF

# ============================================================================
# Media service tunables (optional)
# ============================================================================
# MEDIA_MAX_SIZE=33554432                # 32 MiB
# MEDIA_UPLOAD_EXPIRY=900
# MEDIA_VIEW_EXPIRY=3600
# MEDIA_VIEW_CACHE_TTL=                  # default = 90% of MEDIA_VIEW_EXPIRY
# MEDIA_VIEW_CONCURRENCY=10
# MEDIA_PURGE_AFTER=604800               # 7 days
# MEDIA_PAGE_SIZE=50
# MEDIA_MAX_PAGE_SIZE=100
# MEDIA_DELETE_MAX_DEPTH=3

# ============================================================================
# Scheduler — label-scheduled media maintenance crons (commands/scheduler.py)
# Standard 5-field cron expressions.
# ============================================================================
# CRON_MEDIA_SOFT_DELETE_INVALID=0 * * * *    # hourly: soft-delete invalid media
# CRON_MEDIA_PURGE=30 3 * * *                 # daily 03:30: purge expired media

# ============================================================================
# Telemetry — OpenTelemetry OTLP/gRPC exporter (optional)
# Standard OTEL_* env vars. Defaults to localhost:4317 if unset.
# The docker compose stack runs Arize Phoenix (compose.phoenix.yml): it listens
# OTLP/gRPC on :4317 (the default below) — just `docker compose up` and view the
# LangGraph/agent traces at the Phoenix UI: http://localhost:6006
# ============================================================================
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=doci
# OTEL_EXPORTER_OTLP_PROTOCOL=grpc
# OTEL_SDK_DISABLED=false
